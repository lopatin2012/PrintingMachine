# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.sqlite
*.sqlite3
*.db

# =============================================================================
# 5. Зависимости и виртуальные окружения
# =============================================================================
# Node.js
node_modules/
bower_components/

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.env/
.Python

# PHP
vendor/

# Java / Kotlin
target/
.gradle/
build/

# =============================================================================
# 6. Сборка и дистрибутив (Build artifacts)
# =============================================================================
dist/
build/
out/
*.min.js
*.min.css
*.o
*.obj
*.so
*.dll
*.exe

# =============================================================================
# 7. Тестирование и покрытие кода (Coverage)
