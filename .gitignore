coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =============================================================================
# 8. Прочее и временные файлы
# =============================================================================
.cache/
.temp/
tmp/
temp/
*.tmp
*.bak
*.orig

# =============================================================================
# 9. Специфичные для пакетных менеджеров (опционально)
# =============================================================================
# Обычно lock-файлы НУЖНО коммитить для воспроизводимости сборок,
# но если вы разрабатываете библиотеку, иногда их игнорируют:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# poetry.lock
# Pipfile.lock